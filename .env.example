# ────────────────────────────────────────────────────────────────
#  환경변수 예시 — 이 파일을 복사해서 .env 로 만들고 값을 채우세요.
#    cp .env.example .env      (Windows PowerShell: Copy-Item .env.example .env)
#  .env 는 .gitignore 로 커밋되지 않습니다. 절대 커밋하지 마세요.
# ────────────────────────────────────────────────────────────────

# 서버 포트 (기본 5000)
PORT=5000

# ── Supabase (선택) ────────────────────────────────────────────
# 설정하면 리뷰가 Supabase에 저장됩니다(여러 PC/방문자 공유).
# 비워두면 로컬 JSON 파일(data/reviews.local.json)로 폴백합니다.
# 프로젝트: https://app.supabase.com  → Project Settings → API 에서 확인
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# 서버 전용. 쓰기(리뷰 등록/삭제)에는 service_role 키 권장. 클라이언트에 절대 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=
# service_role 이 없으면 anon 키로 폴백 시도 (RLS 정책에 따라 쓰기 제한될 수 있음)
SUPABASE_ANON_KEY=

# ── 관리자 ─────────────────────────────────────────────────────
# 리뷰 삭제용 관리자 비밀번호. 미설정 시 관리자 로그인은 항상 차단(fail-closed).
ADMIN_PASSWORD=

# ── Kakao (좌표 지오코딩 스크립트용, 선택) ─────────────────────
# scripts/geocode.mjs 에서 새 주소를 좌표로 변환할 때 사용하는 REST API 키.
# (지도 표시용 JS 키와는 다른 키입니다. Kakao Developers → 앱 → REST API 키)
KAKAO_REST_API_KEY=
